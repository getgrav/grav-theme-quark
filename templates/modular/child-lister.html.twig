{# Test template for issue #4098 reproduction.
   Mirrors beejay41's setup: "one module displays its child pages".
   Iterates regular (non-modular) children of the modular parent page and
   renders each child two ways: (1) {{ child.content|raw }} — the normal path,
   honors child's `process: twig`; (2) {{ evaluate_twig(child.content|raw, …) }}
   — the user's workaround pattern, forces Twig processing regardless. #}
<section class="section" style="padding:2rem;background:#f5f5f5;border:2px dashed #999;margin:1rem 0;">
    <h2 style="margin-top:0;">child-lister module</h2>
    <p style="color:#666;font-size:0.85em;">Iterates <code>page.parent.children.nonModular()</code>.</p>

    {% for child in page.parent.children.nonModular() %}
        <article style="background:white;padding:1rem;margin:1rem 0;border-left:4px solid #c4c;">
            <header style="margin-bottom:0.5rem;font-weight:bold;color:#444;">
                {{ child.title }}
                <small style="color:#888;font-weight:normal;">
                    ({{ child.slug }}, process.twig = {{ child.shouldProcess('twig') ? 'true' : 'false' }})
                </small>
            </header>

            <h4 style="margin:0.5rem 0 0.25rem;color:#666;">Path 1: {{ '{{ child.content|raw }}' }}</h4>
            <div style="padding:0.5rem;background:#fafafa;">{{ child.content|raw }}</div>

            <h4 style="margin:0.75rem 0 0.25rem;color:#666;">Path 2: {{ '{{ evaluate_twig(child.content|raw, {page: child}) }}' }}</h4>
            <div style="padding:0.5rem;background:#fafafa;">{{ evaluate_twig(child.content|raw, {page: child})|raw }}</div>
        </article>
    {% endfor %}
</section>
